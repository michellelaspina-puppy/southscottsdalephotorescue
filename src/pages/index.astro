---
import Layout from '../layouts/Layout.astro';
---

<Layout title="South Scottsdale Photo Rescue">
  <main>
    <h1>South Scottsdale Photo Rescue</h1>
    <p>Professional photo restoration and rescue services in South Scottsdale.</p>

    <h2>Our Services</h2>
    <ul>
      <li>Photo restoration</li>
      <li>Photo digitization</li>
      <li>Damaged photo repair</li>
      <li>Photo archiving</li>
    </ul>

    <h2>Contact Us</h2>
    <p>Email: southscottsdalephotorescue@gmail.com</p>
    <p>Phone: (480) 570-0334</p>
  </main>
</Layout>

<style>
  main {
    max-width: 800px;
    margin: 0 auto;
    padding: 2rem;
    font-family: system-ui, sans-serif;
  }
  h1 {
    color: #333;
  }
  ul {
    line-height: 1.8;
  }
</style>